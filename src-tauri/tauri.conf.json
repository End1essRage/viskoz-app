{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "viskoz-app",
  "version": "0.1.0",
  "identifier": "com.yourorg.runnermanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "viskoz-app",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/viskoz-cli"],
    "resources": []
  }
}
