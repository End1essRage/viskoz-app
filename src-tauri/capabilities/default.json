{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Разрешения главного окна: запуск sidecar CLI",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "viskoz-cli",
          "sidecar": true
        }
      ]
    },
    "store:default"
  ]
}